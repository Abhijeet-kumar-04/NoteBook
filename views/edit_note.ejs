<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style1.css">
    <link rel="stylesheet" href="/stylesheets/style2.css">
</head>
<body>
    <div class="main">
        <form action="/edit-note/<%= encodeURIComponent(filename) %>" method="POST">
            <div class="header">
                <img src="/images/notes.png" alt="notes" width="90">
            <h1><input type="text" name="filename" value="<%= filename %>" readonly style="background:transparent;border:none;color:#fff;font-size:1.2em;"></h1>
            </div>
            <h3 style="margin-top: 20px; font-size: 1.6rem; color: aqua;">Content From Here :</h3>
            <div class="content">
                <textarea name="content" rows="10" style="width:100%;font-size:1em;"><%= content %></textarea>
            </div>
            <div style="display: flex;justify-content: space-between;">
                <div>
                    <button class="save-bttn" type="submit">Save</button>
                </div>
                <div>
                    <a class="Go-bttn" href="/">Go back</a>
                </div>
            </div>
            
            
            
        </form>
    </div>

</body>
</html>